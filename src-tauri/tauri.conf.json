{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "jm-boom",
  "version": "0.4.3",
  "identifier": "com.ppxb.jmboom",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "JM Boom",
        "width": 1068,
        "height": 680,
        "minWidth": 800,
        "minHeight": 600,
        "transparent": true,
        "visible": true,
        "center": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPCACHE/reader/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQyQ0FFRTBBREU1RUJFOTcKUldTWHZsN2VDdTdLUXZ3dnJETXR3L3ZtelhZWFEwL2xkaTlNOEdRc0xmSTFia3IzcnNQdzArc0IK",
      "endpoints": [
        "https://github.com/ppxb/jm-boom/releases/latest/download/latest.json"
      ]
    }
  }
}
